{
  "category_titles": {
    "book": "MyStyle Books:",
    "proceedings": "MyStyle Proceedings:",
    "thesis": "MyStyle Theses:",
    "monograph_excerpt": "MyStyle Book Chapters:",
    "newspaper": "MyStyle Newspapers:",
    "archive": "MyStyle Archives:",
    "journal": "MyStyle Journals:",
    "electronic": "MyStyle Online Resources:",
    "other": "MyStyle Others:"
  },
  "docx_style": {
    "font_cn": "ÂÆã‰Ωì",
    "font_en": "Times New Roman",
    "font_size_half_points": 24,
    "line_spacing_twips": 360
  },
  "rules": {
    "strip_page_for_non_excerpt_types": [
      "M",
      "C"
    ],
    "page_merge_exclude_categories": [
      "book"
    ]
  },
  "category_detection": {
    "type_to_category": {
      "M": "book",
      "C": "proceedings",
      "D": "thesis",
      "N": "newspaper",
      "A": "archive",
      "J": "journal",
      "EB/OL": "electronic"
    },
    "excerpt": {
      "type": "M",
      "marker": "//",
      "category": "monograph_excerpt"
    },
    "electronic_keywords": [
      "/OL"
    ],
    "fallback": "other"
  },
  "reference_span_patterns": [
    "^(.+?\\[M\\](?://.+?)?\\.\\s*.+?[,Ôºå]\\s*\\d{4}(?:\\s*[:Ôºö]\\s*[^.\\[]+)?\\.)",
    "^(.+?\\[C\\](?://.+?)?\\.\\s*.+?[,Ôºå]\\s*\\d{4}(?:\\s*[:Ôºö]\\s*[^.\\[]+)?\\.)",
    "^(.+?\\[D\\]\\.\\s*.+?[,Ôºå]\\s*\\d{4}(?:\\s*[:Ôºö]\\s*[^.\\[]+)?\\.)",
    "^(.+?\\[A\\]\\.\\s*.+?[,Ôºå]\\s*\\d{4}(?:\\s*[:Ôºö]\\s*[^.\\[]+)?\\.)",
    "^(.+?\\[J\\]\\.\\s*.+?[,Ôºå]\\s*\\d{4}[^.]*\\.)",
    "^(.+?\\[N\\]\\.\\s*.+?\\d{4}-\\d{2}-\\d{2}(?:\\([^)]+\\))?(?:\\s*[:Ôºö]\\s*[^.\\s]+)?\\.)",
    "^(.*?\\[EB/OL\\].*?(?:https?://\\S+))"
  ],
  "normalization_rules": [
    {
      "name": "book_or_proceedings",
      "regex": "^(?P<author>.+?)\\.\\s*(?P<title>.+?)\\[(?P<type>M|C)\\]\\.\\s*(?P<place>.+?)\\s*[:Ôºö]\\s*(?P<publisher>.+?)\\s*[,Ôºå]\\s*(?P<year>\\d{4})(?:\\s*[:Ôºö]\\s*(?P<pages>[^.\\[]+))?\\.\\s*$",
      "template": "{author}. {title}[{type}]. {place}: {publisher}, {year}."
    },
    {
      "name": "thesis",
      "regex": "^(?P<author>.+?)\\.\\s*(?P<title>.+?)\\[D\\]\\.\\s*(?P<place>.+?)\\s*[:Ôºö]\\s*(?P<publisher>.+?)\\s*[,Ôºå]\\s*(?P<year>\\d{4})(?:\\s*[:Ôºö]\\s*(?P<pages>[^.\\[]+))?\\.\\s*$",
      "template": "{author}. {title}[D]. {place}: {publisher}, {year}."
    },
    {
      "name": "archive",
      "regex": "^(?P<author>.+?)\\.\\s*(?P<title>.+?)\\[A\\]\\.\\s*(?P<place>.+?)\\s*[:Ôºö]\\s*(?P<publisher>.+?)\\s*[,Ôºå]\\s*(?P<year>\\d{4})(?:\\s*[:Ôºö]\\s*(?P<pages>[^.\\[]+))?\\.\\s*$",
      "template": "{author}. {title}[A]. {place}: {publisher}, {year}."
    },
    {
      "name": "newspaper",
      "regex": "^(?P<author>.+?)\\.\\s*(?P<title>.+?)\\[N\\]\\.\\s*(?P<newspaper>.+?)\\s*[,Ôºå]\\s*(?P<date>\\d{4}-\\d{2}-\\d{2})(?P<issue>\\([^)]+\\))?\\.\\s*$",
      "template": "{author}. {title}[N]. {newspaper}, {date}{issue}."
    },
    {
      "name": "journal",
      "regex": "^(?P<author>.+?)\\.\\s*(?P<title>.+?)\\[J\\]\\.\\s*(?P<journal>.+?)\\s*[,Ôºå]\\s*(?P<year>\\d{4})\\s*[,Ôºå]\\s*(?P<volume_issue>[^:Ôºö]+)\\s*[:Ôºö]\\s*(?P<pages>[^.]+)\\.\\s*$",
      "template": "{author}. {title}. {journal} ({year}) {volume_issue}:{pages}."
    }
  ]
}
